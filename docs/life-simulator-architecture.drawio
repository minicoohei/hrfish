        <!-- ラウンドループ 注釈（v7更新） -->
        <!-- ============================== -->
        <mxCell id="loop_note" value="v7 ラウンドループ（×50回）&#xa;&#xa;Phase 1: 環境変化&#xa;  tick_round() → 年齢加算、ブロッカー解消チェック&#xa;  LifeEventEngine.evaluate() → イベント判定&#xa;  apply_event() → CareerState更新&#xa;&#xa;Phase 2: ペルソナ同期&#xa;  PersonaRenderer → system_message再生成&#xa;  agent.update_system_message() ← camel-ai既存API&#xa;  user_info.profile / description も同時更新&#xa;&#xa;Phase 3: OASIS env.step()&#xa;  既存: POST / COMMENT / LIKE / FOLLOW / INTERVIEW&#xa;          GROUP / SEARCH / DO_NOTHING&#xa;  新規: INTERNAL_MONOLOGUE / CONSULT / DECIDE&#xa;&#xa;Phase 4: 資産計算&#xa;  salary → cash_buffer 更新、ローン返済&#xa;&#xa;Phase 5: スナップショット&#xa;  AgentState → ローカルDB&#xa;  ZepGraphMemoryUpdater → Zep書き戻し" style="shape=note;whiteSpace=wrap;html=1;fillColor=#ffffcc;strokeColor=#cccc00;fontSize=10;align=left;spacingLeft=10;backgroundOutline=1;size=18;" vertex="1" parent="1">
          <mxGeometry x="830" y="1590" width="380" height="360" as="geometry" />
        </mxCell>

        <!-- ============================== -->
        <!-- 設計哲学 注釈 -->
        <!-- ============================== -->
        <mxCell id="philosophy_note" value="設計哲学: OASIS活用 + 最小限拡張&#xa;&#xa;- OASISのSNSインタラクション（28アクション）をそのまま活用&#xa;- フォークせず、3つのActionTypeのみ追加&#xa;- ChatAgent.update_system_message() で毎ラウンド&#xa;  エージェントペルソナを動的更新（既存API）&#xa;- BaseIdentity（不変）と CareerState（可変）の分離&#xa;- ブロッカーエンジンで現実的な制約をシミュレート" style="shape=note;whiteSpace=wrap;html=1;fillColor=#e6ffcc;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=10;backgroundOutline=1;size=18;" vertex="1" parent="1">
