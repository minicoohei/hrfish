# ===========================================
# MiroFish Environment Variables
# ===========================================
# Copy this file to .env and fill in the values
# cp .env.example .env
# ===========================================

# ============= LLM Configuration =============
# Supports any LLM API with OpenAI SDK format
# Recommended: Alibaba Qwen-plus via Bailian Platform
LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
# LLM_CHAT_MODEL_NAME=          # Optional: separate model for interactive chat

# ============= Zep Cloud =============
# Free tier: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key

# ============= Security (Production) =============
# MIROFISH_API_KEY=your_strong_random_key    # API authentication (omit to disable)
# SECRET_KEY=your_strong_secret_key          # Flask session secret (auto-generated if omitted)
# CORS_ORIGINS=http://localhost:3000         # Comma-separated allowed origins
# FLASK_DEBUG=False                          # Never enable in production

# ============= Optional =============
# TAVILY_API_KEY=                # Web search for knowledge curation
# OASIS_DEFAULT_MAX_ROUNDS=10   # Default simulation rounds
